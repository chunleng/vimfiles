{
  "mcpServers": {
    "calculator": {
      "args": [
        "mcp-server-calculator"
      ],
      "autoApprove": [
        "calculate"
      ],
      "command": "uvx",
      "env": {
        "ASDF_PYTHON_VERSION": "3.12.11",
        "ASDF_UV_VERSION": "0.10.4"
      }
    },
    "todoist": {
      "autoApprove": [
        "find-activity",
        "find-comments",
        "find-completed-tasks",
        "find-projects",
        "find-tasks",
        "find-tasks-by-date",
        "search",
        "find-labels"
      ],
      "disabled": false,
      "disabled_prompts": [
        "productivity-analysis"
      ],
      "disabled_resources": [],
      "disabled_tools": [
        "list-workspaces",
        "user-info",
        "update-sections",
        "project-management",
        "manage-assignments",
        "find-sections",
        "find-project-collaborators",
        "fetch",
        "fetch-object",
        "get-overview",
        "delete-object",
        "add-filters",
        "view-attachment",
        "update-filters",
        "find-filters",
        "get-productivity-stats",
        "reorder-objects",
        "add-sections",
        "add-projects",
        "project-move",
        "update-projects"
      ],
      "headers": {
        "Authorization": "Bearer ${env:TODOIST_API_KEY}"
      },
      "type": "http",
      "url": "https://ai.todoist.net/mcp"
    }
  },
  "nativeMCPServers": {
    "mcphub": {
      "disabled": true
    },
    "neovim": {
      "disabled": false,
      "disabled_prompts": [
        "parrot"
      ],
      "disabled_resources": [
        "neovim://buffer",
        "neovim://workspace"
      ],
      "disabled_tools": [
        "delete_items",
        "edit_file",
        "execute_command",
        "execute_lua",
        "find_files",
        "list_directory",
        "move_item",
        "read_file",
        "read_multiple_files",
        "write_file"
      ]
    }
  }
}
